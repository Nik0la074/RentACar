@model RentACar.Web.ViewModels.SearchCarsViewModel

@{
    ViewData["Title"] = "Make a Reservation";
}

<h2>Make a Reservation</h2>

<form asp-action="Search" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Search Available Cars</button>
        </div>
    </div>
</form>

@if (Model.AvailableCars.Any())
{
    <h4 class="mt-4">Available Cars</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Brand</th>
                <th>Model</th>
                <th>Year</th>
                <th>Seats</th>
                <th>Price/Day</th>
                <th>Description</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model.AvailableCars)
            {
                <tr>
                    <td>@car.Brand</td>
                    <td>@car.Model</td>
                    <td>@car.Year</td>
                    <td>@car.Seats</td>
                    <td>@car.PricePerDay €/day</td>
                    <td>@car.Description</td>
                    <td>
                        <form asp-action="Reserve" method="post">
                            <input type="hidden" name="CarId" value="@car.Id" />
                            <input type="hidden" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                            <button type="submit" class="btn btn-success btn-sm">Reserve</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else if (Context.Request.Method == "POST")
{
    <div class="alert alert-warning mt-4">No available cars for the selected dates.</div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}